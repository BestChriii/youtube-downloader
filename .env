# Lista video da scaricare separati da virgola (facoltativo, non è obbligatorio).
VIDEOS_URL=

# Playlist da scaricare (facoltativo, non è obbligatorio).
PLAYLISTS_URL=

# Cartella dove verranno salvati i video.
VIDEOS_DIR=downloads

# Cartella dove si trova ffmpeg nel sistema.
FFMPEG_PATH=C:/Program Files/ffmpeg/bin